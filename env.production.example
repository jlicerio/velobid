# VeloBid Linux-host Docker deployment example.
# Create /srv/velobid/secrets/velobid.env from this file on the host.

# Public API/UI binding. Use 127.0.0.1 when fronting with Caddy/Nginx.
VELOBID_BIND_ADDR=0.0.0.0
VELOBID_PORT=8000

# Hermes should usually stay local-only unless a reverse proxy/VPN controls access.
HERMES_BIND_ADDR=127.0.0.1
HERMES_PORT=8644

# Persistent host storage.
VELOBID_CONFIG_DIR=/srv/velobid/config
VELOBID_PROJECTS_DIR=/srv/velobid/bid_projects
VELOBID_DATA_DIR=/srv/velobid/data
HERMES_STATE_DIR=/srv/velobid/hermes
VELOBID_ENV_FILE=/srv/velobid/secrets/velobid.env

# Optional containerized Tailscale identity for VeloBid.
# Use this when VeloBid should appear as its own tailnet node.
TAILSCALE_HOSTNAME=velobid
TAILSCALE_TAILNET=tailfceaca.ts.net
TAILSCALE_STATE_DIR=/srv/velobid/tailscale
TAILSCALE_AUTHKEY=
TAILSCALE_EXTRA_ARGS=

# Hermes runtime.
HERMES_API_KEY=change-me
HERMES_MODEL=deepseek-v4-flash
HERMES_PROVIDER=opencode-go
HERMES_BASE_URL=https://opencode.ai/zen/go/v1
HERMES_CREDENTIALS_JSON=

# Local agent model routing (cost control).
# Fast tier handles simple chat, deep tier handles project-heavy/tool-heavy prompts.
AGENT_MODEL_ROUTING_ENABLED=true
AGENT_MODEL_FAST=deepseek-v4-flash
DEEPSEEK_MODEL=deepseek-v4-pro
AGENT_MODEL_FORCE_DEEP=false
AGENT_MAX_TOKENS_FAST=900
AGENT_MAX_TOKENS_DEEP=2200
AGENT_ALLOW_TOOLS_ON_LOW_COMPLEXITY=false

# Stripe billing (production scaffold).
# Keep disabled until Stripe keys, products, and webhook are configured.
STRIPE_ENABLED=false

# API credentials from Stripe Dashboard > Developers > API keys.
# Use live keys in production and store this env file with strict permissions.
STRIPE_SECRET_KEY=sk_live_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Public URLs used by Stripe Checkout and Billing Portal redirects.
# Replace velobid.example.com with your production domain.
STRIPE_CHECKOUT_SUCCESS_URL=https://velobid.example.com/settings/billing?checkout=success
STRIPE_CHECKOUT_CANCEL_URL=https://velobid.example.com/settings/billing?checkout=canceled
STRIPE_PORTAL_RETURN_URL=https://velobid.example.com/settings/billing

# Stripe recurring price IDs mapped to app plans.
STRIPE_PRICE_ID=price_replace_me
STRIPE_PRICE_ID_STARTER=price_replace_me
STRIPE_PRICE_ID_PRO=price_replace_me
STRIPE_PRICE_ID_ENTERPRISE=price_replace_me

# Webhook route expected by the VeloBid API.
STRIPE_WEBHOOK_PATH=/api/v1/billing/stripe/webhook

# Agent access controls (trial + abuse protection).
# Trial starts automatically on first authenticated agent call if no Stripe
# subscription/trial state exists yet.
AGENT_TRIAL_DAYS=14
AGENT_RATE_LIMIT_COMPANY_PER_MINUTE=30
AGENT_RATE_LIMIT_COMPANY_PER_HOUR=600
AGENT_RATE_LIMIT_COMPANY_PER_DAY=5000
AGENT_RATE_LIMIT_USER_PER_MINUTE=12
AGENT_RATE_LIMIT_USER_PER_HOUR=240

# Backup storage.
VELOBID_BACKUP_DIR=/srv/velobid/backups
VELOBID_RETAIN_LOCAL_BACKUPS=14

# Optional encrypted offsite backup with restic.
# RESTIC_REPOSITORY=s3:s3.us-west-004.backblazeb2.com/my-bucket/velobid
# RESTIC_PASSWORD=change-me
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
